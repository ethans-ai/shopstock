<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<title>Labels — Dymo 30252</title>
<style>
  @page { size: 3.5in 1.125in; margin: 0; }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: Arial, Helvetica, sans-serif; background: #fff; color: #000; color-scheme: only light; }
  .label {
    width: 3.5in; height: 1.125in;
    padding: 0.08in 0.12in;
    display: flex; align-items: center; gap: 0.12in;
    overflow: hidden;
    page-break-after: always;
  }
  .qr { width: 0.95in; height: 0.95in; flex: 0 0 auto; }
  .qr svg { width: 100%; height: 100%; }
  .txt { min-width: 0; }
  .name {
    font-size: 11pt; font-weight: bold; line-height: 1.15;
    display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
  }
  .sub { font-size: 7.5pt; color: #333; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .code { font-size: 9pt; font-family: Consolas, monospace; letter-spacing: 0.08em; }
  .print-note { padding: 8px; background: #ffec9e; font-size: 14px; }
  @media print { .print-note { display: none; } }
</style>
</head>
<body>
<div class="print-note">
  Dymo 30252 roll · print at <strong>100% scale, margins: none</strong>. One label per page.
  <% if (!baseUrlSet) { %><strong style="color:#b00">⚠️ Base URL not set!</strong><% } %>
  <button onclick="print()">Print</button>
</div>
<% for (const l of labels) { %>
  <div class="label">
    <div class="qr"><%- l.qrSvg %></div>
    <div class="txt">
      <div class="name"><%= l.name %></div>
      <div class="code"><%= l.code %></div>
      <% if (l.sub) { %><div class="sub"><%= l.sub %></div><% } %>
    </div>
  </div>
<% } %>
</body>
</html>
